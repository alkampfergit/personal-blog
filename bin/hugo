#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
HUGO_VERSION="${HUGO_VERSION:-0.148.1}"
TARGET_BIN="$ROOT_DIR/.tools/hugo/$HUGO_VERSION/hugo"

if [[ ! -x "$TARGET_BIN" ]]; then
  echo "Pinned Hugo $HUGO_VERSION is not installed in this repository." >&2
  echo "Run: $ROOT_DIR/scripts/install-hugo.sh" >&2
  exit 1
fi

exec "$TARGET_BIN" "$@"
